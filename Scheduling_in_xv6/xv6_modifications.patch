diff --git a/kernel/trap.c b/kernel/trap.c
index a41cd69..e222c59 100644
--- a/kernel/trap.c
+++ b/kernel/trap.c
@@ -80,9 +80,46 @@ usertrap(void)
   if(killed(p))
     kexit(-1);
 
+#if defined(CFS)
+  // Give up the CPU after the calculated time slice has expired
+  if(which_dev == 2) {     // This is a timer interrupt
+    struct proc *p = myproc();
+
+    if(p && p->state == RUNNING) {
+      // Update vruntime by the number of ticks the process runs.
+      p->vruntime += (1024 / p->weight);
+      p->ticks_run++;
+
+      // Countint all competing processes: RUNNING and RUNNABLE
+      int num_competitors = 0;
+      struct proc *iter_p;
+
+      for(iter_p = proc; iter_p < &proc[NPROC]; iter_p++) {
+        if(iter_p->state == RUNNABLE) {
+          num_competitors++;
+        }
+      }
+      num_competitors++;  // Add the current RUNNING process to the count.
+
+      // Now, calculate the time slice based on the number of competitors.
+      int timeslice = TARGET_LATENCY / num_competitors;
+      if (timeslice < 3) {
+        timeslice = 3; // Enforce a minimum time slice of 3 ticks.
+      }
+
+      // If the process has run for its calculated time slice, it must yield.
+      if (p->ticks_run >= timeslice) {
+        p->ticks_run = 0; // Reset counter for its next turn
+        yield();
+      }
+    }
+  }
+
+#elif !defined(FCFS)
   // give up the CPU if this is a timer interrupt.
   if(which_dev == 2)
     yield();
+#endif
 
   prepare_return();
 
